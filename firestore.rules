rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // events/{roomCode} — 방 문서
    match /events/{roomCode} {
      // 누구나 방 존재 여부 확인(읽기) 가능, 생성 가능
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['code', 'createdAt', 'password', 'name'])
                    && request.resource.data.code == roomCode;
      // password 해시 마이그레이션만 허용, 삭제는 본인(방 주인)만
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['password']);
      allow delete: if true;

      // events/{roomCode}/settings/{docId} — 공유 설정
      match /settings/{docId} {
        allow read, write: if true;
      }

      // events/{roomCode}/records/{recordId} — 축의금 기록
      match /records/{recordId} {
        allow read: if true;
        // 생성: 필수 필드 + 타입 검증
        allow create: if request.resource.data.keys().hasAll(['id', 'name', 'amount', 'side', 'createdAt'])
                      && request.resource.data.name is string
                      && request.resource.data.amount is number
                      && request.resource.data.amount > 0
                      && request.resource.data.side in ['신랑', '신부']
                      && (!('num' in request.resource.data) || request.resource.data.num is number);
        // 수정: 주요 필드만 변경 가능
        allow update: if request.resource.data.name is string
                      && request.resource.data.amount is number
                      && request.resource.data.amount > 0
                      && request.resource.data.side in ['신랑', '신부']
                      && (!('num' in request.resource.data) || request.resource.data.num is number);
        // 삭제 허용
        allow delete: if true;
      }
    }

    // 그 외 모든 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
